<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <section class="hero">
    <div style="font-size: 4rem; margin-bottom: 1rem;">🌾</div>
    <h1>Farm Fresh, Direct to You</h1>
    <p>Connecting farmers directly with buyers. No middlemen, fair prices, fresh produce — with secure escrow payment.</p>
    
    <% if (!user) { %>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/auth/register" class="btn btn-primary" style="padding: 0.75rem 2rem;">Get Started</a>
        <a href="/auth/login" class="btn btn-outline" style="padding: 0.75rem 2rem;">Log In</a>
      </div>
    <% } else { %>
      <a href="/<%= user.role %>/dashboard" class="btn btn-primary" style="padding: 0.75rem 2rem;">Go to Dashboard →</a>
    <% } %>
  </section>

  <section class="container" style="padding: 3rem 1.5rem;">
    <h2 style="text-align: center; margin-bottom: 2rem;">How It Works</h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
      <div class="card" style="text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🧑‍🌾</div>
        <h3 style="margin-bottom: 0.75rem;">For Farmers</h3>
        <p style="color: var(--text-light); font-size: 0.9rem;">List your crops, set your price, receive payments directly to your account.</p>
      </div>
      
      <div class="card" style="text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🛒</div>
        <h3 style="margin-bottom: 0.75rem;">For Buyers</h3>
        <p style="color: var(--text-light); font-size: 0.9rem;">Browse fresh produce, place orders, track delivery in real-time.</p>
      </div>
      
      <div class="card" style="text-align: center;">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🔒</div>
        <h3 style="margin-bottom: 0.75rem;">Secure Escrow</h3>
        <p style="color: var(--text-light); font-size: 0.9rem;">Payment held safely until delivery confirmed. Zero risk for both parties.</p>
      </div>
    </div>
  </section>

  <% if (listings && listings.length > 0) { %>
  <section class="container" style="padding: 0 1.5rem 3rem;">
    <h2 style="text-align: center; margin-bottom: 2rem;">Recent Listings</h2>
    
    <div class="card-grid">
      <% listings.forEach(listing => { %>
        <div class="listing-card">
          <% if (listing.images && listing.images.length > 0) { %>
            <img src="<%= listing.images[0] %>" alt="<%= listing.cropName %>">
          <% } else { %>
            <div style="width: 100%; height: 200px; background: linear-gradient(135deg, #dcfce7, #86efac); display: flex; align-items: center; justify-content: center; font-size: 3rem;">🌿</div>
          <% } %>
          
          <div class="listing-card-body">
            <h3><%= listing.cropName %></h3>
            <p style="font-size: 0.85rem; color: var(--text-light); margin: 0.25rem 0;">By <%= listing.farmer.name %></p>
            <p class="price">₹<%= listing.pricePerUnit %>/<%= listing.unit %></p>
            <div class="meta">
              <span><%= listing.quantity %> <%= listing.unit %> available</span>
              <% if (listing.organic) { %>
                <span class="badge badge-success">Organic</span>
              <% } %>
            </div>
            <% if (user && user.role === 'buyer') { %>
              <a href="/buyer/listing/<%= listing._id %>" class="btn btn-primary btn-sm" style="width: 100%; margin-top: 0.75rem; text-align: center;">View Details</a>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <footer style="background: #f9fafb; padding: 2rem 0; margin-top: 4rem; text-align: center; color: #6b7280; font-size: 0.9rem;">
    <div class="container">
      <p>&copy; 2024 Farmer Direct Market. Connecting farmers with buyers.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
