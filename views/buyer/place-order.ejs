<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <div class="container" style="max-width: 700px;">
    <div class="page-header">
      <h1>Place Order</h1>
      <p>Confirm your order details</p>
    </div>

    <div class="card">
      <h2 style="font-size: 1.25rem; margin-bottom: 1rem;">Order Summary</h2>
      
      <div style="display: flex; gap: 1rem; padding: 1rem; background: var(--secondary); border-radius: 0.5rem; margin-bottom: 1.5rem;">
        <% if (listing.images && listing.images.length > 0) { %>
          <img src="<%= listing.images[0] %>" alt="<%= listing.cropName %>" style="width: 80px; height: 80px; object-fit: cover; border-radius: 0.5rem;">
        <% } %>
        <div>
          <h3 style="font-size: 1.1rem; margin-bottom: 0.25rem;"><%= listing.cropName %></h3>
          <p style="color: var(--text-light); font-size: 0.85rem;">By <%= listing.farmer.name %></p>
          <p style="font-size: 1.25rem; font-weight: 700; color: var(--primary); margin-top: 0.5rem;">
            ₹<%= listing.pricePerUnit %>/<%= listing.unit %>
          </p>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
      <% } %>

      <form action="/buyer/order/<%= listing._id %>" method="POST">
        <div class="form-group">
          <label for="quantity">Quantity (<%= listing.unit %>) *</label>
          <input 
            type="number" 
            id="quantity" 
            name="quantity" 
            required 
            min="0.01" 
            step="0.01" 
            max="<%= listing.quantity %>"
            placeholder="Enter quantity"
            oninput="calculateTotal()"
          >
          <p style="font-size: 0.8rem; color: var(--text-light); margin-top: 0.25rem;">
            Available: <%= listing.quantity %> <%= listing.unit %>
          </p>
        </div>

        <div style="background: #f9fafb; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
            <span>Price per <%= listing.unit %>:</span>
            <span style="font-weight: 600;">₹<%= listing.pricePerUnit %></span>
          </div>
          <div style="display: flex; justify-content: space-between; font-size: 1.25rem; font-weight: 700; color: var(--primary);">
            <span>Total Amount:</span>
            <span id="totalAmount">₹0</span>
          </div>
        </div>

        <h3 style="font-size: 1.1rem; margin-bottom: 1rem;">Delivery Address</h3>

        <div class="form-group">
          <label for="address">Street Address *</label>
          <input type="text" id="address" name="address" required placeholder="123 Main Street" value="<%= buyer.location?.address || '' %>">
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <label for="city">City *</label>
            <input type="text" id="city" name="city" required placeholder="Mumbai" value="<%= buyer.location?.city || '' %>">
          </div>

          <div class="form-group">
            <label for="state">State *</label>
            <input type="text" id="state" name="state" required placeholder="Maharashtra" value="<%= buyer.location?.state || '' %>">
          </div>
        </div>

        <div class="form-group">
          <label for="pincode">Pincode *</label>
          <input type="text" id="pincode" name="pincode" required pattern="[0-9]{6}" placeholder="400001" value="<%= buyer.location?.pincode || '' %>">
        </div>

        <div class="form-group">
          <label for="phone">Contact Phone *</label>
          <input type="tel" id="phone" name="phone" required pattern="[0-9]{10}" placeholder="9876543210" value="<%= buyer.phone || '' %>">
        </div>

        <div style="background: #dbeafe; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; font-size: 0.85rem; color: #1e40af;">
          🔒 <strong>Secure Payment:</strong> You'll be redirected to Razorpay for secure payment. Your money will be held in escrow until you confirm delivery.
        </div>

        <div style="display: flex; gap: 1rem;">
          <button type="submit" class="btn btn-primary" style="flex: 1;">Proceed to Payment</button>
          <a href="/buyer/listing/<%= listing._id %>" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </div>

  <script>
    const pricePerUnit = <%= listing.pricePerUnit %>;
    
    function calculateTotal() {
      const quantity = parseFloat(document.getElementById('quantity').value) || 0;
      const total = quantity * pricePerUnit;
      document.getElementById('totalAmount').textContent = '₹' + total.toLocaleString('en-IN', { maximumFractionDigits: 2 });
    }
  </script>
  <script src="/js/main.js"></script>
</body>
</html>
